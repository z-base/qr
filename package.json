{
  "name": "@z-base/qr",
  "version": "1.0.2",
  "description": "Simple managed QR display, print, and scan utilities for browser frontends.",
  "keywords": [
    "qr",
    "qrcode",
    "scanner",
    "browser",
    "frontend",
    "spa",
    "esm",
    "typescript",
    "z-base"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/z-base/qr.git"
  },
  "bugs": {
    "url": "https://github.com/z-base/qr/issues"
  },
  "homepage": "https://z-base.github.io/qr",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "format": "prettier . --write",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "prepare": "husky",
    "prepublishOnly": "npm run test"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@playwright/test": "^1.58.2",
    "@types/escape-html": "^1.0.4",
    "@types/node": "^25.3.3",
    "c8": "^11.0.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "qr": "^0.5.4",
    "qr-scanner": "^1.4.2"
  }
}
